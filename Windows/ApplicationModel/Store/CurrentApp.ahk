     * A unique transaction ID is required for each instance of a consumable product that has been purchased more than once.
     * @param {HSTRING} productId The product ID of the consumable add-on to report as fulfilled.
     * @param {Guid} transactionId The transaction ID for the purchase of the consumable add-on.
     * @returns {IAsyncOperation<Integer>} 
     * @see https://learn.microsoft.com/uwp/api/windows.applicationmodel.store.currentapp.reportconsumablefulfillmentasync
     */
    static ReportConsumableFulfillmentAsync(productId, transactionId) {
        if (!CurrentApp.HasProp("__ICurrentAppWithConsumables")) {
            activatableClassId := HSTRING.Create("Windows.ApplicationModel.Store.CurrentApp")
            factoryPtr := WinRT.RoGetActivationFactory(activatableClassId, ICurrentAppWithConsumables.IID)
            CurrentApp.__ICurrentAppWithConsumables := ICurrentAppWithConsumables(factoryPtr)
        }

        return CurrentApp.__ICurrentAppWithConsumables.ReportConsumableFulfillmentAsync(productId, transactionId)
    }

