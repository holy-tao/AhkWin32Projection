#Include ..\..\..\Win32\System\WinRT\Apis.ahk
#Include ..\..\..\Win32\System\WinRT\HSTRING.ahk
#Include ..\..\..\Win32\System\WinRT\IInspectable.ahk
#Include .\IStorePreview.ahk
#Include ..\..\..\..\Guid.ahk

/**
 * Defines static methods for retrieving the in-app product SKUs available for the current app and requesting the purchase of an in-app product SKU for the app.
 * @remarks
 * 
 * @see https://learn.microsoft.com/uwp/api/windows.applicationmodel.store.preview.storepreview
 * @namespace Windows.ApplicationModel.Store.Preview
 * @version WindowsRuntime 1.4
 */
class StorePreview extends IInspectable {
;@region Static Methods
    /**
     * Requests the purchase of a SKU for an in-app product that is associated with the current app. Calling this method displays the UI that is used to complete the transaction via the Microsoft Store.
     * @remarks
     * The [StorePreviewSkuInfo.ProductId](storepreviewskuinfo_productid.md) and [StorePreviewProductInfo.ProductId](storepreviewproductinfo_productid.md) values are not the same as the [Windows.ApplicationModel.Store.ProductListing.ProductId](../windows.applicationmodel.store/productlisting_productid.md) value. [Windows.ApplicationModel.Store.ProductListing.ProductId](../windows.applicationmodel.store/productlisting_productid.md) is specified by the developer as they create an in-app product in [Partner Center](https://partner.microsoft.com/dashboard). The [StorePreviewSkuInfo.ProductId](storepreviewskuinfo_productid.md) and [StorePreviewProductInfo.ProductId](storepreviewproductinfo_productid.md) values are generated by Microsoft.
     * @param {HSTRING} productId Specifies the ID of the in-app product. This corresponds to the [StorePreviewProductInfo.ProductId](storepreviewproductinfo_productid.md) value and the [StorePreviewSkuInfo.ProductId](storepreviewskuinfo_productid.md) values for all SKUs of the in-app product.
     * @param {HSTRING} skuId Specifies the ID of the SKU for the in-app product. This corresponds to the [StorePreviewSkuInfo.SkuId](storepreviewskuinfo_skuid.md) value.
     * @returns {IAsyncOperation<StorePreviewPurchaseResults>} 
     * @see https://learn.microsoft.com/uwp/api/windows.applicationmodel.store.preview.storepreview.requestproductpurchasebyproductidandskuidasync
     */
    static RequestProductPurchaseByProductIdAndSkuIdAsync(productId, skuId) {
        if (!StorePreview.HasProp("__IStorePreview")) {
            activatableClassId := HSTRING.Create("Windows.ApplicationModel.Store.Preview.StorePreview")
            factoryPtr := WinRT.RoGetActivationFactory(activatableClassId, IStorePreview.IID)
            StorePreview.__IStorePreview := IStorePreview(factoryPtr)
        }

        return StorePreview.__IStorePreview.RequestProductPurchaseByProductIdAndSkuIdAsync(productId, skuId)
    }

    /**
     * Retrieves the in-app products available for the current app asynchronously, including the available SKUs for each product.
     * @returns {IAsyncOperation<IVectorView<StorePreviewProductInfo>>} 
     * @see https://learn.microsoft.com/uwp/api/windows.applicationmodel.store.preview.storepreview.loadaddonproductinfosasync
     */
    static LoadAddOnProductInfosAsync() {
        if (!StorePreview.HasProp("__IStorePreview")) {
            activatableClassId := HSTRING.Create("Windows.ApplicationModel.Store.Preview.StorePreview")
            factoryPtr := WinRT.RoGetActivationFactory(activatableClassId, IStorePreview.IID)
            StorePreview.__IStorePreview := IStorePreview(factoryPtr)
        }

        return StorePreview.__IStorePreview.LoadAddOnProductInfosAsync()
    }

;@endregion Static Methods

;@region Instance Methods
    __New(ptr) {
        super.__New(ptr)
    }

;@endregion Instance Methods
}
