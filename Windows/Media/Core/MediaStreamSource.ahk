     * @returns {MediaStreamSource} 
     * @see https://learn.microsoft.com/uwp/api/windows.media.core.mediastreamsource.#ctor
     */
    static CreateFromDescriptors(descriptor, descriptor2) {
        if (!MediaStreamSource.HasProp("__IMediaStreamSourceFactory")) {
            activatableClassId := HSTRING.Create("Windows.Media.Core.MediaStreamSource")
            factoryPtr := WinRT.RoGetActivationFactory(activatableClassId, IMediaStreamSourceFactory.IID)
            MediaStreamSource.__IMediaStreamSourceFactory := IMediaStreamSourceFactory(factoryPtr)
        }

        return MediaStreamSource.__IMediaStreamSourceFactory.CreateFromDescriptors(descriptor, descriptor2)
    }

