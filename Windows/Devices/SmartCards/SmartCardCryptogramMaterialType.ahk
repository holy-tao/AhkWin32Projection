#Requires AutoHotkey v2.0.0 64-bit
#Include ..\..\..\Win32Enum.ahk

/**
 * Defines the cryptogram material type.
 * @remarks
 * 
 * @see https://learn.microsoft.com/uwp/api/windows.devices.smartcards.smartcardcryptogrammaterialtype
 * @namespace Windows.Devices.SmartCards
 * @version WindowsRuntime 1.4
 */
class SmartCardCryptogramMaterialType extends Win32Enum{

    /**
     * The material doesn't have a data type.
     * @type {Integer (Int32)}
     */
    static None => 0

    /**
     * The material is static data for authentication.
     * @type {Integer (Int32)}
     */
    static StaticDataAuthentication => 1

    /**
     * The material data is generated using TripleDes112.
     * @type {Integer (Int32)}
     */
    static TripleDes112 => 2

    /**
     * The material is data that is generated using AES.
     * @type {Integer (Int32)}
     */
    static Aes => 3

    /**
     * The material is data that is generated by using RSA according to PKCS #1
     * @type {Integer (Int32)}
     */
    static RsaPkcs1 => 4
}
