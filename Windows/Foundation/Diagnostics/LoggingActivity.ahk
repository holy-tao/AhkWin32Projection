     * @param {Integer} level The logging level.
     * @returns {LoggingActivity} 
     * @see https://learn.microsoft.com/uwp/api/windows.foundation.diagnostics.loggingactivity.#ctor
     */
    static CreateLoggingActivityWithLevel(activityName, loggingChannel_, level) {
        if (!LoggingActivity.HasProp("__ILoggingActivityFactory")) {
