            factoryPtr := WinRT.RoGetActivationFactory(activatableClassId, ILoggingActivityFactory.IID)
            LoggingActivity.__ILoggingActivityFactory := ILoggingActivityFactory(factoryPtr)
        }

        return LoggingActivity.__ILoggingActivityFactory.CreateLoggingActivityWithLevel(activityName, loggingChannel_, level)
    }

