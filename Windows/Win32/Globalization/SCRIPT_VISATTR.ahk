#Requires AutoHotkey v2.1-alpha.26+ 64-bit

/**
 * Contains the visual (glyph) attributes that identify clusters and justification points, as generated by ScriptShape.
 * @see https://learn.microsoft.com/windows/win32/api/usp10/ns-usp10-script_visattr
 * @namespace Windows.Win32.Globalization
 */
export default struct SCRIPT_VISATTR {
    #StructPack 2

    /**
     * This bitfield backs the following members:
     * - uJustification
     * - fClusterStart
     * - fDiacritic
     * - fZeroWidth
     * - fReserved
     * - fShapeReserved
     */
    _bitfield : Int16


    /**
     * @type {Integer}
     */
    uJustification {
        get => (this._bitfield >> 0) & 0xF
        set => this._bitfield := ((value & 0xF) << 0) | (this._bitfield & ~(0xF << 0))
    }

    /**
     * @type {Integer}
     */
    fClusterStart {
        get => (this._bitfield >> 4) & 0x1
        set => this._bitfield := ((value & 0x1) << 4) | (this._bitfield & ~(0x1 << 4))
    }

    /**
     * @type {Integer}
     */
    fDiacritic {
        get => (this._bitfield >> 5) & 0x1
        set => this._bitfield := ((value & 0x1) << 5) | (this._bitfield & ~(0x1 << 5))
    }

    /**
     * @type {Integer}
     */
    fZeroWidth {
        get => (this._bitfield >> 6) & 0x1
        set => this._bitfield := ((value & 0x1) << 6) | (this._bitfield & ~(0x1 << 6))
    }

    /**
     * @type {Integer}
     */
    fReserved {
        get => (this._bitfield >> 7) & 0x1
        set => this._bitfield := ((value & 0x1) << 7) | (this._bitfield & ~(0x1 << 7))
    }

    /**
     * @type {Integer}
     */
    fShapeReserved {
        get => (this._bitfield >> 8) & 0xFF
        set => this._bitfield := ((value & 0xFF) << 8) | (this._bitfield & ~(0xFF << 8))
    }
}
