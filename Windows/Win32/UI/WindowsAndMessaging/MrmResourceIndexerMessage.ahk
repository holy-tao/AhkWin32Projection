#Requires AutoHotkey v2.1-alpha.26+ 64-bit
#Import ".\MrmResourceIndexerMessageSeverity.ahk" { MrmResourceIndexerMessageSeverity }
#Import "..\..\Foundation\PWSTR.ahk" { PWSTR }

/**
 * Represents a message generated by a resource indexer. For more info, and scenario-based walkthroughs of how to use these APIs, see Package resource indexing (PRI) APIs and custom build systems.
 * @see https://learn.microsoft.com/windows/win32/menurc/mrmresourceindexermessage
 * @namespace Windows.Win32.UI.WindowsAndMessaging
 */
export default struct MrmResourceIndexerMessage {
    #StructPack 8

    /**
     * Type: **[**MrmResourceIndexerMessageSeverity**](mrmresourceindexermessageseverity.md)**
     * 
     * 
     * A value indicating the severity of the message.
     */
    severity : MrmResourceIndexerMessageSeverity

    /**
     * Type: **ULONG**
     * 
     * 
     * A unique identifier for the message.
     */
    id : UInt32

    /**
     * Type: **PCWSTR**
     * 
     * 
     * The text of the message. Do not free this pointer; the memory is owned by the operating system.
     */
    text : PWSTR

}
