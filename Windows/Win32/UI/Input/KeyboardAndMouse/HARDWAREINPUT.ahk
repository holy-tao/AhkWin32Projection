#Requires AutoHotkey v2.1-alpha.26+ 64-bit

/**
 * Contains information about a simulated message generated by an input device other than a keyboard or mouse.
 * @see https://learn.microsoft.com/windows/win32/api/winuser/ns-winuser-hardwareinput
 * @namespace Windows.Win32.UI.Input.KeyboardAndMouse
 */
export default struct HARDWAREINPUT {
    #StructPack 4

    /**
     * Type: <b>DWORD</b>
     * 
     * The message generated by the input hardware.
     */
    uMsg : UInt32

    /**
     * Type: <b>WORD</b>
     * 
     * The low-order word of the <i>lParam </i> parameter for <b>uMsg</b>.
     */
    wParamL : UInt16

    /**
     * Type: <b>WORD</b>
     * 
     * The high-order word of the <i>lParam </i> parameter for <b>uMsg</b>.
     */
    wParamH : UInt16

}
